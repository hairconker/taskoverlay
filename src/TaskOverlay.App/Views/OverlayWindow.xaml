<Window x:Class="TaskOverlay.App.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TaskOverlay.Core.Models;assembly=TaskOverlay.Core"
        Title="TaskOverlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResizeWithGrip"
        ShowInTaskbar="False"
        Width="320"
        Height="180"
        MinWidth="280"
        MinHeight="120"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="AccentBrush" Color="#FF22D3EE"/>
        <SolidColorBrush x:Key="AccentMutedBrush" Color="#FF67E8F9"/>
        <SolidColorBrush x:Key="PrimaryTextBrush" Color="#FFF8FAFC"/>
        <SolidColorBrush x:Key="MutedTextBrush" Color="#FFB7C2D2"/>
        <SolidColorBrush x:Key="SubtleTextBrush" Color="#FF8B95A1"/>
        <SolidColorBrush x:Key="TaskRowBrush" Color="#1FFFFFFF"/>
        <SolidColorBrush x:Key="TaskRowHoverBrush" Color="#2BFFFFFF"/>
        <SolidColorBrush x:Key="ControlSurfaceBrush" Color="#331E293B"/>
        <SolidColorBrush x:Key="InputSurfaceBrush" Color="#EE111827"/>
        <SolidColorBrush x:Key="ViewBorderBrush" Color="#4D7DD3FC"/>
        <SolidColorBrush x:Key="EditBorderBrush" Color="#AA22D3EE"/>

        <Style x:Key="OverlayButtonStyle" TargetType="Button">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="10,4"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#3D94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#4D164E63"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9922D3EE"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#CC0E7490"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryOverlayButtonStyle" TargetType="Button" BasedOn="{StaticResource OverlayButtonStyle}">
            <Setter Property="Background" Value="#CC0891B2"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource OverlayButtonStyle}">
            <Setter Property="Width" Value="26"/>
            <Setter Property="MinHeight" Value="24"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource InputSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#667DD3FC"/>
            <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Margin" Value="0"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>
        <Style TargetType="ToggleButton">
            <Setter Property="MinHeight" Value="28"/>
            <Setter Property="Padding" Value="9,4"/>
            <Setter Property="Margin" Value="3,2"/>
            <Setter Property="Foreground" Value="{StaticResource PrimaryTextBrush}"/>
            <Setter Property="Background" Value="{StaticResource ControlSurfaceBrush}"/>
            <Setter Property="BorderBrush" Value="#3D94A3B8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#6615B8A6"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#AA22D3EE"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#9922D3EE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border x:Name="Shell"
            CornerRadius="14"
            BorderBrush="{StaticResource ViewBorderBrush}"
            BorderThickness="1"
            Padding="9"
            MouseLeftButtonDown="Shell_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect x:Name="ShellShadow"
                              BlurRadius="18"
                              ShadowDepth="0"
                              Opacity="0.16"
                              Color="#000000"/>
        </Border.Effect>
        <DockPanel LastChildFill="True">
            <Grid x:Name="ViewHeader" DockPanel.Dock="Top" Margin="0,0,0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="☰"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="1,0,8,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TaskOverlay"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="13.5"
                               FontWeight="SemiBold"/>
                    <Border Width="1"
                            Height="15"
                            Background="#33FFFFFF"
                            Margin="10,0"/>
                    <TextBlock Text="Ctrl+`"
                               Foreground="{StaticResource AccentMutedBrush}"
                               FontSize="11.5"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Border Grid.Column="2"
                        Background="#2415B8A6"
                        CornerRadius="7"
                        Padding="6,2"
                        VerticalAlignment="Center">
                    <TextBlock Foreground="{StaticResource AccentMutedBrush}" FontSize="11">
                        <Run Text="{Binding Items.Count, Mode=OneWay}"/>
                        <Run Text=" 项"/>
                    </TextBlock>
                </Border>
            </Grid>

            <Grid x:Name="EditHeader" DockPanel.Dock="Top" Margin="0,0,0,8" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="☰"
                           Foreground="{StaticResource MutedTextBrush}"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="1,0,8,0"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="TaskOverlay"
                               Foreground="{StaticResource PrimaryTextBrush}"
                               FontSize="13.5"
                               FontWeight="SemiBold"/>
                    <Border Width="1"
                            Height="15"
                            Background="#33FFFFFF"
                            Margin="10,0"/>
                    <TextBlock Text="编辑模式"
                               Foreground="{StaticResource AccentMutedBrush}"
                               FontSize="11.5"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <Button Grid.Column="2" Content="完成" Style="{StaticResource PrimaryOverlayButtonStyle}" Click="EditButton_OnClick"/>

                <Grid Grid.Row="1" Grid.ColumnSpan="3" Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="1" Content="任务中心" Style="{StaticResource OverlayButtonStyle}" Click="OpenManagement_OnClick"/>
                    <ToggleButton x:Name="TopmostToggle"
                                  Grid.Column="2"
                                  Content="置顶"
                                  Checked="TopmostToggle_OnChecked"
                                  Unchecked="TopmostToggle_OnUnchecked"/>
                </Grid>
            </Grid>

            <StackPanel x:Name="EditPanel" DockPanel.Dock="Top" Visibility="Collapsed" Margin="0,0,0,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="32"
                            Height="32"
                            Background="{StaticResource ControlSurfaceBrush}"
                            BorderBrush="#4D7DD3FC"
                            BorderThickness="1"
                            CornerRadius="8"
                            VerticalAlignment="Center"
                            Margin="3">
                        <TextBlock Text="+"
                                   Foreground="{StaticResource PrimaryTextBrush}"
                                   FontSize="20"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   Margin="0,-2,0,0"/>
                    </Border>
                    <TextBox x:Name="QuickAddTextBox"
                             Grid.Column="1"
                             Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"/>
                    <Button Grid.Column="2" Content="添加" Style="{StaticResource PrimaryOverlayButtonStyle}" Click="AddTask_OnClick"/>
                </Grid>
                <WrapPanel Margin="0,3,0,0">
                    <Button Content="每日任务" Style="{StaticResource OverlayButtonStyle}" Click="AddDailyTask_OnClick"/>
                    <Button Content="刷新" Style="{StaticResource OverlayButtonStyle}" Click="Refresh_OnClick"/>
                </WrapPanel>
            </StackPanel>

            <TextBlock DockPanel.Dock="Bottom"
                       Text="{Binding ErrorMessage}"
                       Foreground="#FFFCA5A5"
                       FontSize="12"
                       TextWrapping="Wrap"
                       Margin="2,6,2,0"/>

            <Grid>
                <ListBox ItemsSource="{Binding Items}"
                         Background="Transparent"
                         BorderThickness="0"
                         Foreground="{StaticResource PrimaryTextBrush}"
                         ScrollViewer.VerticalScrollBarVisibility="Auto"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ListBoxItem">
                                        <ContentPresenter/>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:TaskItem}">
                            <Border x:Name="TaskCard"
                                    Padding="7,5"
                                    Margin="0,0,0,4"
                                    Background="{StaticResource TaskRowBrush}"
                                    CornerRadius="8"
                                    BorderBrush="#18FFFFFF"
                                    BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{Binding IsCompleted, Mode=OneWay}" Click="TaskCheck_OnClick"/>
                                    <Grid Grid.Column="1" Margin="3,0,6,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{Binding Title}"
                                                   Foreground="{StaticResource PrimaryTextBrush}"
                                                   FontSize="12.5"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DueAt, StringFormat={}{0:HH:mm}}"
                                                   Foreground="{StaticResource AccentMutedBrush}"
                                                   FontSize="10.2"
                                                   TextAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Margin="8,0,0,0"/>
                                    </Grid>
                                    <Button x:Name="DeleteButton"
                                            Grid.Column="2"
                                            Content="×"
                                            Visibility="Collapsed"
                                            Style="{StaticResource IconButtonStyle}"
                                            Click="DeleteTask_OnClick"/>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding RelativeSource={RelativeSource AncestorType=Window}, Path=IsEditMode}" Value="True">
                                    <Setter TargetName="TaskCard" Property="Background" Value="#2E164E63"/>
                                    <Setter TargetName="TaskCard" Property="BorderBrush" Value="#6622D3EE"/>
                                    <Setter TargetName="DeleteButton" Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <TextBlock Text="今天还没有待办。&#x0a;Ctrl+` 进入编辑态后即可快速添加。"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextAlignment="Center"
                           TextWrapping="Wrap"
                           VerticalAlignment="Center"
                           Margin="20"
                           IsHitTestVisible="False">
                    <TextBlock.Style>
                        <Style TargetType="TextBlock">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </TextBlock.Style>
                </TextBlock>
            </Grid>
        </DockPanel>
    </Border>
</Window>
