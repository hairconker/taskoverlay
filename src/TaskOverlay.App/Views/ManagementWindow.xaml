<Window x:Class="TaskOverlay.App.Views.ManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TaskOverlay.Core.Models;assembly=TaskOverlay.Core"
        Title="TaskOverlay 任务中心"
        Width="1180"
        Height="680"
        MinWidth="980"
        MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#FFF1F5F9"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="PrimaryBrush" Color="#FF0891B2"/>
        <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#FF0E7490"/>
        <SolidColorBrush x:Key="Slate900Brush" Color="#FF0F172A"/>
        <SolidColorBrush x:Key="Slate700Brush" Color="#FF334155"/>
        <SolidColorBrush x:Key="Slate500Brush" Color="#FF64748B"/>
        <SolidColorBrush x:Key="CardBorderBrush" Color="#FFE2E8F0"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="Margin" Value="4,2"/>
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource Slate700Brush}"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFEFF6FF"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="#FF7DD3FC"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FFE0F2FE"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource PrimaryBrush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource PrimaryHoverBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#FF155E75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Foreground" Value="#FFB91C1C"/>
            <Setter Property="BorderBrush" Value="#FFFECACA"/>
            <Setter Property="Background" Value="#FFFEF2F2"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="Margin" Value="0,3,0,7"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="PasswordBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="9,6"/>
            <Setter Property="Margin" Value="0,3,0,7"/>
            <Setter Property="BorderBrush" Value="#FFCBD5E1"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Margin" Value="0,3,0,7"/>
        </Style>
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16"/>
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource Slate700Brush}"/>
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#FFF1F5F9"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
            <Setter Property="RowHeight" Value="42"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#FFF8FAFC"/>
            <Setter Property="Foreground" Value="{StaticResource Slate700Brush}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="8"/>
            <Setter Property="BorderBrush" Value="{StaticResource CardBorderBrush}"/>
        </Style>
        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Slate900Brush}"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="HintStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Slate500Brush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="TextWrapping" Value="Wrap"/>
        </Style>
        <HierarchicalDataTemplate DataType="{x:Type models:PlanningItem}" ItemsSource="{Binding Children}">
            <Border Background="#FFF8FAFC"
                    BorderBrush="#FFE2E8F0"
                    BorderThickness="1"
                    CornerRadius="7"
                    Padding="10"
                    Margin="0,0,0,6">
                <StackPanel>
                    <WrapPanel>
                        <TextBlock Text="{Binding TimeBlock}" Foreground="{StaticResource PrimaryBrush}" FontWeight="SemiBold" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Title}" Foreground="{StaticResource Slate900Brush}" FontWeight="SemiBold"/>
                    </WrapPanel>
                    <TextBlock Text="{Binding Reason}" Style="{StaticResource HintStyle}" Margin="0,3,0,0"/>
                    <TextBlock Text="{Binding GoalTitle, StringFormat=关联目标：{0}}" Margin="0,2,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource HintStyle}">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding GoalTitle}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding GoalTitle}" Value="">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <WrapPanel Margin="0,4,0,0">
                        <TextBlock Text="{Binding Kind, StringFormat=类型：{0}}" Foreground="{StaticResource Slate500Brush}" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding Priority, StringFormat=优先级：{0}}" Foreground="{StaticResource Slate500Brush}" FontSize="11" Margin="0,0,12,0"/>
                        <TextBlock Text="{Binding DueAt, StringFormat=截止：{0:MM-dd HH:mm}}" Foreground="{StaticResource Slate500Brush}" FontSize="11"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </HierarchicalDataTemplate>
    </Window.Resources>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="#FF0B1120" Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="TaskOverlay 任务中心" Foreground="White" FontSize="21" FontWeight="SemiBold"/>
                    <TextBlock Text="先快速记录，再集中规划；本地 JSON 默认保存，启动无需等待数据库。" Foreground="#FFCBD5E1" Margin="0,4,0,0"/>
                </StackPanel>
                <Border Grid.Column="1" Background="#1A22D3EE" BorderBrush="#6638BDF8" BorderThickness="1" CornerRadius="14" Padding="12,6" VerticalAlignment="Center">
                    <TextBlock Text="本地 JSON · Ctrl+`" Foreground="#FF67E8F9" FontSize="12"/>
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Margin="16,0,16,12"
                Padding="10"
                Background="#FFFEF2F2"
                BorderBrush="#FFFECACA"
                BorderThickness="1"
                CornerRadius="6">
            <Border.Style>
                <Style TargetType="Border">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="{x:Null}">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding ErrorMessage}" Value="">
                            <Setter Property="Visibility" Value="Collapsed"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#FFB91C1C" TextWrapping="Wrap"/>
        </Border>

        <TabControl x:Name="TaskTabs" Margin="14,10,14,12" SelectionChanged="TaskTabs_OnSelectionChanged">
            <TabItem x:Name="TasksTab" Header="任务中心">
                <DockPanel Margin="8">
                    <StackPanel DockPanel.Dock="Top">
                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Margin="0,0,14,0" VerticalAlignment="Center">
                                    <TextBlock Text="快速记录" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="先写下来，稍后再补时间和提醒。" Style="{StaticResource HintStyle}"/>
                                </StackPanel>
                                <TextBox Grid.Column="1"
                                         Margin="0"
                                         VerticalAlignment="Center"
                                         Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"/>
                                <WrapPanel Grid.Column="2" Margin="8,0,0,0" VerticalAlignment="Center">
                                    <Button Content="添加到今天" Style="{StaticResource PrimaryButtonStyle}" Click="AddTask_OnClick"/>
                                    <Button Content="添加每日任务" Click="AddDailyTask_OnClick"/>
                                    <Button Content="打开详细编辑" Click="NewDetails_OnClick"/>
                                </WrapPanel>
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource CardStyle}" Margin="0,0,0,10" Padding="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="150"/>
                                    <ColumnDefinition Width="230"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <ComboBox SelectedValue="{Binding Filter}" SelectedValuePath="Tag" Margin="0">
                                    <ComboBoxItem Content="今天待处理" Tag="{x:Static models:TaskFilter.Today}"/>
                                    <ComboBoxItem Content="明天" Tag="{x:Static models:TaskFilter.Tomorrow}"/>
                                    <ComboBoxItem Content="未来 7 天" Tag="{x:Static models:TaskFilter.ThisWeek}"/>
                                    <ComboBoxItem Content="已过期" Tag="{x:Static models:TaskFilter.Overdue}"/>
                                    <ComboBoxItem Content="已完成" Tag="{x:Static models:TaskFilter.Completed}"/>
                                    <ComboBoxItem Content="全部任务" Tag="{x:Static models:TaskFilter.All}"/>
                                </ComboBox>
                                <TextBox Grid.Column="1" Margin="12,0,0,0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"/>
                                <Button Grid.Column="2" Content="搜索" Style="{StaticResource PrimaryButtonStyle}" Click="Refresh_OnClick"/>
                                <TextBlock Grid.Column="3" Text="可按标题、备注或标签搜索" Style="{StaticResource HintStyle}" VerticalAlignment="Center" Margin="10,0"/>
                                <Button Grid.Column="4" Content="刷新" Click="Refresh_OnClick"/>
                            </Grid>
                        </Border>
                    </StackPanel>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="390" MinWidth="320"/>
                        </Grid.ColumnDefinitions>
                        <Grid Margin="0,0,12,0">
                            <DataGrid ItemsSource="{Binding Items}"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      HorizontalScrollBarVisibility="Auto"
                                      IsReadOnly="True">
                                <DataGrid.Columns>
                                    <DataGridCheckBoxColumn Binding="{Binding IsCompleted}" Header="完成" Width="54"/>
                                    <DataGridTextColumn Binding="{Binding Title}" Header="任务" Width="*"/>
                                    <DataGridTextColumn Binding="{Binding Priority}" Header="优先级" Width="72"/>
                                    <DataGridTextColumn Binding="{Binding DueAt, StringFormat={}{0:MM-dd HH:mm}}" Header="截止" Width="106"/>
                                    <DataGridTextColumn Binding="{Binding ScheduleSummary}" Header="重复" Width="82"/>
                                    <DataGridTextColumn Binding="{Binding TagSummary}" Header="标签" Width="110"/>
                                    <DataGridTemplateColumn Header="操作" Width="142">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition/>
                                                        <ColumnDefinition/>
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition/>
                                                        <RowDefinition/>
                                                    </Grid.RowDefinitions>
                                                    <Button Content="编辑" Click="EditTask_OnClick" Padding="8,3" MinHeight="28"/>
                                                    <Button Grid.Column="1" Content="删除" Style="{StaticResource DangerButtonStyle}" Click="DeleteTask_OnClick" Padding="8,3" MinHeight="28"/>
                                                    <Button Grid.Row="1" Grid.ColumnSpan="2" Content="完成/恢复" Click="ToggleTask_OnClick" Padding="8,3" MinHeight="28"/>
                                                </Grid>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                            <TextBlock Text="当前列表为空。&#x0a;可先使用上方“快速记录”，或在右侧补充完整任务信息。"
                                       Foreground="{StaticResource Slate500Brush}"
                                       TextAlignment="Center"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center"
                                       Margin="24"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Items.Count}" Value="0">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>

                        <GridSplitter Grid.Column="1"
                                      Width="8"
                                      HorizontalAlignment="Stretch"
                                      VerticalAlignment="Stretch"
                                      Background="Transparent"
                                      ResizeBehavior="PreviousAndNext"
                                      ShowsPreview="True"/>

                        <Border Grid.Column="2" Style="{StaticResource CardStyle}">
                            <DockPanel LastChildFill="True">
                                <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                    <TextBlock Text="{Binding EditorHeading}" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="用于补充截止时间、提醒、标签和重复计划。" Style="{StaticResource HintStyle}" Margin="0,2,0,0"/>
                                </StackPanel>

                                <Border DockPanel.Dock="Bottom"
                                        Background="White"
                                        BorderBrush="{StaticResource CardBorderBrush}"
                                        BorderThickness="0,1,0,0"
                                        Padding="0,10,0,0"
                                        Margin="0,10,0,0">
                                    <WrapPanel>
                                        <Button Content="保存任务" Style="{StaticResource PrimaryButtonStyle}" Click="SaveDetails_OnClick"/>
                                        <Button Content="清空表单" Click="NewDetails_OnClick"/>
                                    </WrapPanel>
                                </Border>

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                    <TextBlock Text="标题"/>
                                    <TextBox Text="{Binding EditorTitle, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="备注"/>
                                    <TextBox Text="{Binding EditorNotes, UpdateSourceTrigger=PropertyChanged}" Height="68" AcceptsReturn="True" TextWrapping="Wrap"/>
                                    <TextBlock Text="优先级"/>
                                    <ComboBox ItemsSource="{Binding Priorities}" SelectedItem="{Binding EditorPriority}"/>
                                    <TextBlock Text="截止时间"/>
                                    <TextBox Text="{Binding EditorDueAtText, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="格式：yyyy-MM-dd HH:mm，可留空" Style="{StaticResource HintStyle}"/>
                                    <TextBlock Text="提醒时间" Margin="0,7,0,0"/>
                                    <TextBox Text="{Binding EditorReminderAtText, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="重复任务会保留相对截止时间的提醒偏移。" Style="{StaticResource HintStyle}"/>
                                    <TextBlock Text="标签" Margin="0,7,0,0"/>
                                    <TextBox Text="{Binding EditorTagsText, UpdateSourceTrigger=PropertyChanged}"/>
                                    <TextBlock Text="多个标签使用逗号分隔" Style="{StaticResource HintStyle}"/>

                                    <Expander Header="重复计划（可选）" Margin="0,8,0,0">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="重复类型"/>
                                            <ComboBox ItemsSource="{Binding RecurrenceKinds}" SelectedItem="{Binding EditorRecurrenceKind}"/>
                                            <TextBlock Text="重复间隔"/>
                                            <TextBox Text="{Binding EditorRecurrenceIntervalText, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="每周执行日"/>
                                            <ComboBox ItemsSource="{Binding DaysOfWeek}" SelectedItem="{Binding EditorRecurrenceDayOfWeek}"/>
                                            <TextBlock Text="每月执行日期"/>
                                            <TextBox Text="{Binding EditorRecurrenceDayOfMonthText, UpdateSourceTrigger=PropertyChanged}"/>
                                            <TextBlock Text="“自定义天数”表示每隔 N 天；规则以截止时间或创建时间为起点。" Style="{StaticResource HintStyle}"/>
                                        </StackPanel>
                                    </Expander>

                                    </StackPanel>
                                </ScrollViewer>
                            </DockPanel>
                        </Border>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem Header="明日规划">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="生成明日计划" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="V1 使用本地算法，不调用 AI。新增任务进入外部提案，已有任务调整只作为建议展示。" Style="{StaticResource HintStyle}" Margin="0,4,0,12"/>
                            <TextBlock Text="规划模式"/>
                            <ComboBox x:Name="PlanningModeBox" SelectedIndex="0" SelectedValuePath="Tag">
                                <ComboBoxItem Content="任务列表模式" Tag="{x:Static models:PlanningMode.TaskList}"/>
                                <ComboBoxItem Content="时间块模式" Tag="{x:Static models:PlanningMode.TimeBlock}"/>
                            </ComboBox>
                            <TextBlock Text="可用时间段（时间块模式）"/>
                            <TextBox x:Name="PlanningWindowsBox" Text="09:00-11:30,14:00-17:30"/>
                            <TextBlock Text="多个时间段用逗号分隔；任务列表模式可留空。" Style="{StaticResource HintStyle}"/>
                            <TextBlock Text="目标摘要（可选）"/>
                            <TextBox x:Name="PlanningGoalBox" Height="80" AcceptsReturn="True" TextWrapping="Wrap"/>
                            <TextBlock Text="本地算法会把目标摘要转成待确认的建议任务。" Style="{StaticResource HintStyle}"/>
                            <TextBlock Text="最多建议数量"/>
                            <TextBox x:Name="PlanningMaxItemsBox" Text="8"/>
                            <WrapPanel Margin="0,10,0,0">
                                <Button Content="生成明日计划" Style="{StaticResource PrimaryButtonStyle}" Click="GeneratePlan_OnClick"/>
                                <Button Content="新增建议进提案箱" Click="AddPlanProposals_OnClick"/>
                            </WrapPanel>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="规划建议" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="PlanningSummaryText" Text="还没有生成计划。" Style="{StaticResource HintStyle}" Margin="0,4,0,0"/>
                                <ItemsControl ItemsSource="{Binding PlanningWarnings, RelativeSource={RelativeSource AncestorType=Window}}" Margin="0,8,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" Foreground="#FFB45309" FontSize="12" TextWrapping="Wrap"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                            <TreeView ItemsSource="{Binding PlanningItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                      BorderThickness="0"
                                      Background="Transparent"/>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem x:Name="GoalsTab" Header="目标库">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="360"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="长期目标" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock x:Name="GoalEditorModeText" Text="新增目标" Style="{StaticResource HintStyle}" Margin="0,4,0,12"/>

                                <TextBlock Text="目标标题"/>
                                <TextBox x:Name="GoalTitleBox"/>
                                <TextBlock Text="描述"/>
                                <TextBox x:Name="GoalDescriptionBox" Height="90" AcceptsReturn="True" TextWrapping="Wrap"/>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="优先级"/>
                                        <ComboBox x:Name="GoalPriorityBox" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="高" Tag="{x:Static models:TaskPriority.High}"/>
                                            <ComboBoxItem Content="普通" Tag="{x:Static models:TaskPriority.Normal}"/>
                                            <ComboBoxItem Content="低" Tag="{x:Static models:TaskPriority.Low}"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="状态"/>
                                        <ComboBox x:Name="GoalStatusBox" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="进行中" Tag="{x:Static models:GoalStatus.Active}"/>
                                            <ComboBoxItem Content="暂停" Tag="{x:Static models:GoalStatus.Paused}"/>
                                            <ComboBoxItem Content="完成" Tag="{x:Static models:GoalStatus.Completed}"/>
                                        </ComboBox>
                                    </StackPanel>
                                </Grid>

                                <Grid Margin="0,6,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="时间范围"/>
                                        <ComboBox x:Name="GoalHorizonBox" SelectedValuePath="Tag">
                                            <ComboBoxItem Content="长期" Tag="{x:Static models:GoalTimeHorizon.LongTerm}"/>
                                            <ComboBoxItem Content="本月" Tag="{x:Static models:GoalTimeHorizon.ThisMonth}"/>
                                            <ComboBoxItem Content="本周" Tag="{x:Static models:GoalTimeHorizon.ThisWeek}"/>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Text="每日投入分钟"/>
                                        <TextBox x:Name="GoalDailyMinutesBox"/>
                                    </StackPanel>
                                </Grid>

                                <TextBlock Text="标签" Margin="0,7,0,0"/>
                                <TextBox x:Name="GoalTagsBox"/>
                                <TextBlock Text="多个标签用逗号分隔；明日规划会继承这些标签。" Style="{StaticResource HintStyle}"/>

                                <TextBlock Text="下一里程碑" Margin="0,7,0,0"/>
                                <TextBox x:Name="GoalMilestoneTitleBox"/>
                                <TextBlock Text="里程碑日期"/>
                                <DatePicker x:Name="GoalMilestoneTargetBox"/>
                                <TextBlock Text="当前版本先管理一个最近里程碑；完整里程碑列表保留在数据文件中。" Style="{StaticResource HintStyle}"/>

                                <WrapPanel Margin="0,12,0,0">
                                    <Button Content="保存目标" Style="{StaticResource PrimaryButtonStyle}" Click="SaveGoal_OnClick"/>
                                    <Button Content="新建" Click="NewGoal_OnClick"/>
                                    <Button Content="刷新" Click="RefreshGoals_OnClick"/>
                                </WrapPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="目标列表" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="进行中的目标会参与本地明日规划；暂停和完成的目标只保存，不会自动生成任务。" Style="{StaticResource HintStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Grid>
                                <DataGrid ItemsSource="{Binding GoalItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          IsReadOnly="True">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Binding="{Binding Title}" Header="目标" Width="*"/>
                                        <DataGridTextColumn Binding="{Binding Priority}" Header="优先级" Width="80"/>
                                        <DataGridTextColumn Binding="{Binding Status}" Header="状态" Width="80"/>
                                        <DataGridTextColumn Binding="{Binding TimeHorizon}" Header="范围" Width="90"/>
                                        <DataGridTextColumn Binding="{Binding DailyBudgetMinutes}" Header="每日分钟" Width="90"/>
                                        <DataGridTextColumn Binding="{Binding TagSummary}" Header="标签" Width="140"/>
                                        <DataGridTextColumn Binding="{Binding Milestones.Count}" Header="里程碑" Width="80"/>
                                        <DataGridTextColumn Binding="{Binding TaskLinks.Count}" Header="关联任务" Width="80"/>
                                        <DataGridTemplateColumn Header="操作" Width="130">
                                            <DataGridTemplateColumn.CellTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Button Content="编辑" Style="{StaticResource PrimaryButtonStyle}" Click="EditGoal_OnClick"/>
                                                        <Button Content="删除" Style="{StaticResource DangerButtonStyle}" Click="DeleteGoal_OnClick"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </DataGridTemplateColumn.CellTemplate>
                                        </DataGridTemplateColumn>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <TextBlock Text="还没有长期目标。先在左侧新增一个，明日规划会自动读取。"
                                           Foreground="{StaticResource Slate500Brush}"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GoalItems.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Grid>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="外部提案">
                <DockPanel Margin="8">
                    <Border DockPanel.Dock="Top" Style="{StaticResource CardStyle}" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="等待确认的任务" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="CLI、AI 或其他程序提交的任务会先进入这里；确认后才会加入正式任务列表。" Style="{StaticResource HintStyle}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="刷新提案" Click="RefreshProposals_OnClick" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Grid>
                        <DataGrid ItemsSource="{Binding ProposalItems, RelativeSource={RelativeSource AncestorType=Window}}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  IsReadOnly="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Title}" Header="任务" Width="*"/>
                                <DataGridTextColumn Binding="{Binding Notes}" Header="备注" Width="220"/>
                                <DataGridTextColumn Binding="{Binding Priority}" Header="优先级" Width="80"/>
                                <DataGridTextColumn Binding="{Binding DueAt, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Header="截止" Width="140"/>
                                <DataGridTextColumn Binding="{Binding ScheduleSummary}" Header="重复" Width="90"/>
                                <DataGridTextColumn Binding="{Binding TagSummary}" Header="标签" Width="120"/>
                                <DataGridTextColumn Binding="{Binding GoalTitle}" Header="目标" Width="130"/>
                                <DataGridTextColumn Binding="{Binding Source}" Header="来源" Width="110"/>
                                <DataGridTextColumn Binding="{Binding CreatedAt, StringFormat={}{0:MM-dd HH:mm}}" Header="提交时间" Width="110"/>
                                <DataGridTemplateColumn Header="操作" Width="170">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="确认加入" Style="{StaticResource PrimaryButtonStyle}" Click="ConfirmProposal_OnClick"/>
                                                <Button Content="拒绝" Style="{StaticResource DangerButtonStyle}" Click="RejectProposal_OnClick"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                        <TextBlock Text="目前没有等待确认的外部任务。"
                                   Foreground="{StaticResource Slate500Brush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ProposalItems.Count, RelativeSource={RelativeSource AncestorType=Window}}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </DockPanel>
            </TabItem>

            <TabItem x:Name="CalendarTab" Header="日历规划">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="350"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource CardStyle}" Margin="0,0,12,0">
                        <StackPanel>
                            <TextBlock Text="选择日期" Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="查看单次任务和重复任务在指定日期的安排。" Style="{StaticResource HintStyle}" Margin="0,2,0,12"/>
                            <Calendar SelectedDate="{Binding SelectedDate}" HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource CardStyle}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                                <TextBlock Text="当日安排" Style="{StaticResource SectionTitleStyle}"/>
                                <TextBlock Text="{Binding SelectedDate, StringFormat=已选择：{0:yyyy-MM-dd}}" Style="{StaticResource HintStyle}"/>
                            </StackPanel>
                            <ListBox ItemsSource="{Binding Items}" BorderThickness="0" Background="Transparent">
                                <ListBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:TaskItem}">
                                        <Border Background="#FFF8FAFC" BorderBrush="#FFE2E8F0" BorderThickness="1" CornerRadius="7" Padding="12" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold" Foreground="{StaticResource Slate900Brush}"/>
                                                <TextBlock Text="{Binding DueAt, StringFormat=截止：{0:yyyy-MM-dd HH:mm}}" Foreground="{StaticResource Slate500Brush}" FontSize="12"/>
                                                <TextBlock Text="{Binding ScheduleSummary, StringFormat=重复：{0}}" Foreground="{StaticResource Slate500Brush}" FontSize="12"/>
                                                <TextBlock Text="{Binding TagSummary, StringFormat=标签：{0}}" Foreground="{StaticResource Slate500Brush}" FontSize="12"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="数据管理">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="数据保护" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="本地 JSON 会自动保存上一版本备份。也可以手动导出到其他位置，或从备份恢复。" Style="{StaticResource HintStyle}" Margin="0,4,0,10"/>
                                    <TextBlock Text="当前数据文件" Foreground="{StaticResource Slate700Brush}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="DataPathText" TextWrapping="Wrap" Foreground="{StaticResource Slate500Brush}" Margin="0,4,0,10"/>
                                    <TextBlock Text="当前设置文件" Foreground="{StaticResource Slate700Brush}" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="SettingsPathText" TextWrapping="Wrap" Foreground="{StaticResource Slate500Brush}" Margin="0,4,0,10"/>
                                    <WrapPanel>
                                        <Button Content="导出备份" Style="{StaticResource PrimaryButtonStyle}" Click="ExportData_OnClick"/>
                                        <Button Content="导入备份" Click="ImportData_OnClick"/>
                                        <Button Content="复制数据路径" Click="CopyDataPath_OnClick"/>
                                        <Button Content="复制保存文件夹" Click="CopyDataFolder_OnClick"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="数据管理说明" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="此页面只负责本地任务数据的备份和恢复。快捷键、透明度、置顶、开机自启和存储方式请前往“设置”页修改。" Style="{StaticResource HintStyle}" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="设置">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid Margin="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Margin="0,0,12,0">
                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="存储后端" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="日常使用推荐本地 JSON：启动快、无网络依赖。只有明确需要共享数据库时再切换 MySQL。" Style="{StaticResource HintStyle}" Margin="0,4,0,10"/>
                                    <TextBlock Text="存储模式"/>
                                    <ComboBox x:Name="StorageBackendBox">
                                        <ComboBoxItem Content="本地 JSON（推荐）" Tag="{x:Static models:TaskStorageBackend.Json}"/>
                                        <ComboBoxItem Content="MySQL（可选）" Tag="{x:Static models:TaskStorageBackend.MySql}"/>
                                    </ComboBox>
                                    <Expander Header="MySQL 连接参数（仅切换 MySQL 时使用）" Margin="0,4,0,0">
                                        <StackPanel Margin="0,8,0,0">
                                            <TextBlock Text="主机"/>
                                            <TextBox x:Name="HostBox"/>
                                            <TextBlock Text="端口"/>
                                            <TextBox x:Name="PortBox"/>
                                            <TextBlock Text="数据库"/>
                                            <TextBox x:Name="DatabaseBox"/>
                                            <TextBlock Text="用户名"/>
                                            <TextBox x:Name="UserBox"/>
                                            <TextBlock Text="密码"/>
                                            <PasswordBox x:Name="PasswordBox"/>
                                        </StackPanel>
                                    </Expander>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource CardStyle}" Margin="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="本地 API 与 CLI" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="只监听 127.0.0.1。外部新增默认进入提案箱，确认后才成为正式任务。" Style="{StaticResource HintStyle}" Margin="0,4,0,10"/>
                                    <CheckBox x:Name="ApiEnabledBox" Content="启用本地 API" Margin="0,4"/>
                                    <TextBlock Text="API 端口"/>
                                    <TextBox x:Name="ApiPortBox"/>
                                    <TextBlock Text="访问令牌"/>
                                    <TextBox x:Name="ApiTokenBox"/>
                                    <WrapPanel>
                                        <Button Content="复制令牌" Click="CopyApiToken_OnClick"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <Border Style="{StaticResource CardStyle}" Margin="0,0,0,12">
                                <StackPanel>
                                    <TextBlock Text="快捷键与悬浮窗" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="在这里查找或修改进入编辑模式的快捷键，以及悬浮窗的显示行为。" Style="{StaticResource HintStyle}" Margin="0,4,0,10"/>
                                    <TextBlock Text="编辑模式快捷键"/>
                                    <TextBox x:Name="HotkeyBox"/>
                                    <TextBlock Text="推荐：Ctrl+`，避开游戏里的数字 1。旧版 ~+1 仍兼容，但游戏中可能失效。" Style="{StaticResource HintStyle}" Margin="0,0,0,7"/>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="悬浮窗背景透明度"/>
                                        <TextBlock x:Name="OpacityValueText"
                                                   Grid.Column="1"
                                                   Foreground="{StaticResource Slate500Brush}"
                                                   FontWeight="SemiBold"/>
                                    </Grid>
                                    <Slider x:Name="OpacitySlider"
                                            Minimum="0.25"
                                            Maximum="1"
                                            TickFrequency="0.05"
                                            IsSnapToTickEnabled="True"
                                            ValueChanged="OpacitySlider_OnValueChanged"
                                            Margin="0,4,0,4"/>
                                    <TextBlock Text="拖动后会立即预览并自动记住。"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,0,0,10"/>
                                    <CheckBox x:Name="TopmostBox"
                                              Content="默认置顶"
                                              Checked="VisualSetting_OnChanged"
                                              Unchecked="VisualSetting_OnChanged"
                                              Margin="0,4"/>
                                    <CheckBox x:Name="StartupBox" Content="开机自启" Margin="0,4"/>
                                    <TextBlock x:Name="VisualSettingsStatusText"
                                               Text="透明度和置顶会自动保存。"
                                               Style="{StaticResource HintStyle}"
                                               Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Style="{StaticResource CardStyle}">
                                <StackPanel>
                                    <TextBlock Text="应用操作" Style="{StaticResource SectionTitleStyle}"/>
                                    <TextBlock Text="快捷键、开机自启、本地 API 和存储设置修改后，点击保存并应用；透明度和置顶会自动保存。" Style="{StaticResource HintStyle}" Margin="0,4,0,10"/>
                                    <WrapPanel>
                                        <Button Content="保存并应用设置" Style="{StaticResource PrimaryButtonStyle}" Click="SaveSettings_OnClick"/>
                                        <Button Content="退出 TaskOverlay" Style="{StaticResource DangerButtonStyle}" Click="ExitApplication_OnClick"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
